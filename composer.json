{
    "name": "vwo/vwo-fme-php-sdk",
    "version": "1.55.0",
    "keywords": ["vwo", "fme", "sdk"],
    "license": "Apache-2.0",
    "authors": [{
        "name": "VWO developers",
        "email": "dev@wingify.com"
    }, {
        "name": "Saksham Gupta",
        "email": "saksham.gupta@vwo.com"
    }],
    "description": "VWO FME PHP SDK — legacy package name; requires wingify/wingify-fme-php-sdk. Provides vwo\\ namespace.",
    "require": {
        "wingify/wingify-fme-php-sdk": "^2.5.0"
    },
    "autoload": {
        "psr-4": {
            "vwo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "vwo\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^6.5 || ^9.5",
        "vwo/vwo-fme-sdk-e2e-test-settings-n-cases": "^1.2.4"
    },
    "scripts": {
        "start": ["cp -r ./git-hooks/* ./.git/hooks/ && chmod -R +x ./.git/hooks/"],
        "test": ["./vendor/bin/phpunit ./tests"],
        "test:legacy": ["./vendor/bin/phpunit ./tests/unit/LegacyNamespaceTest.php"]
    }
}
